/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Permitted-Cross-Domain-Policies: none

/api/*
  Cache-Control: no-store

# Static assets — long cache with hashed filenames (Vite adds content hash)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Icons and static images
/icons/*
  Cache-Control: public, max-age=2592000

# Audio data JSON — short cache, background refresh handles staleness
/data/*
  Cache-Control: public, max-age=300, stale-while-revalidate=1800

# Manifest and PWA files
/manifest.json
  Cache-Control: public, max-age=86400

# Admin page - no cache, no index
/admin.html
  Cache-Control: no-store
  X-Robots-Tag: noindex

# API responses are handled by the Worker (functions/api), not this file

# Audio files optimization (if served from main domain)
/*.mp3
  Cache-Control: public, max-age=2592000, immutable
  Accept-Ranges: bytes
  Access-Control-Allow-Origin: *

/*.opus
  Cache-Control: public, max-age=2592000, immutable
  Accept-Ranges: bytes
  Access-Control-Allow-Origin: *

# R2 audio files (if using custom domain)
/audio/*
  Cache-Control: public, max-age=2592000, immutable
  Accept-Ranges: bytes

# Preconnect hints for faster audio loading
/*
  Link: <https://audio.foyue.org>; rel=preconnect
  Link: <https://opus.foyue.org>; rel=preconnect

# ✅ 注意：audio.foyue.org 和 opus.foyue.org 的缓存头需要在 R2 存储桶配置中设置
# _headers 文件只对当前域名有效，子域名规则不生效
