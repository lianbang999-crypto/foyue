/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Permitted-Cross-Domain-Policies: none

/api/*
  Cache-Control: no-store

# Static assets — long cache with hashed filenames (Vite adds content hash)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Icons and static images
/icons/*
  Cache-Control: public, max-age=2592000

# Audio data JSON — short cache, background refresh handles staleness
/data/*
  Cache-Control: public, max-age=300, stale-while-revalidate=1800

# Manifest and PWA files
/manifest.json
  Cache-Control: public, max-age=86400

# Admin page - no cache, no index
/admin.html
  Cache-Control: no-store
  X-Robots-Tag: noindex

# API responses are handled by the Worker (functions/api), not this file

# Audio files optimization
/*.mp3
  Cache-Control: public, max-age=2592000, immutable
  Accept-Ranges: bytes
  Access-Control-Allow-Origin: *

# Audio subdomain optimization
audio.foyue.org/*
  Cache-Control: public, max-age=2592000, immutable
  Accept-Ranges: bytes
  Access-Control-Allow-Origin: https://foyue.org
  Timing-Allow-Origin: https://foyue.org

# R2 audio files (if using custom domain)
/audio/*
  Cache-Control: public, max-age=2592000, immutable
  Accept-Ranges: bytes

# Preconnect hints for faster audio loading
/*
  Link: <https://pub-7be57e30faae4f81bbd76b61006ac8fc.r2.dev>; rel=preconnect
  Link: <https://pub-8c99ae05414d4672b1ec08a569ab3299.r2.dev>; rel=preconnect
  Link: <https://pub-7a334cb009c14e10bbcfee54bb593a2a.r2.dev>; rel=preconnect
