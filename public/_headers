/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()

/api/*
  Cache-Control: no-store

# Static assets — long cache with hashed filenames (Vite adds content hash)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Icons and static images
/icons/*
  Cache-Control: public, max-age=2592000

# Audio data JSON — short cache, background refresh handles staleness
/data/*
  Cache-Control: public, max-age=300, stale-while-revalidate=1800

# Manifest and PWA files
/manifest.json
  Cache-Control: public, max-age=86400

# API responses are handled by the Worker (functions/api), not this file
